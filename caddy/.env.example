# Caddy Stack Konfiguration
# In Portainer unter Stack > Environment Variables eintragen

# E-Mail für Let's Encrypt Zertifikate
CADDY_ACME_EMAIL=deine@email.de

# JWT Secret für Caddy Security Auth-Portal
# Generieren: openssl rand -base64 48
CADDY_JWT_SECRET=REPLACE_WITH_SECURE_JWT_SECRET

# JWT Secret für CaddyManager Backend
# Generieren: openssl rand -base64 48
CADDYMANAGER_JWT_SECRET=REPLACE_WITH_SECURE_CADDYMANAGER_SECRET
