# Matrix / Synapse Konfiguration
# In Portainer unter Stack > Environment Variables eintragen

# Domain des Matrix-Servers
MATRIX_DOMAIN=matrix.home.pfeiffer-privat.de

# PostgreSQL Passwort generieren:
#   openssl rand -base64 32
POSTGRES_PASSWORD=REPLACE_WITH_SECURE_PASSWORD

# Admin-Account (wird automatisch beim ersten Start angelegt)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=REPLACE_WITH_SECURE_ADMIN_PASSWORD
