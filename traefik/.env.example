# Traefik Stack Konfiguration
# In Portainer unter Stack > Environment Variables eintragen

# E-Mail für Let's Encrypt Zertifikate
TRAEFIK_ACME_EMAIL=deine@email.de

# Basic Auth für Traefik Dashboard
# Hash generieren (auf dem Host ausführen):
#   echo $(htpasswd -nb admin DEIN_PASSWORT) | sed -e 's/\$/\$\$/g'
# Wichtig: $ muss als $$ escaped werden in docker-compose!
TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$xxxx$$yyyy
